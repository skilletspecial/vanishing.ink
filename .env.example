# Port the HTTP server listens on (ONCE expects 80)
PORT=80

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Maximum ciphertext size in bytes (default 100 KB).
# Base64-encoded ciphertext is ~33% larger than plaintext,
# so 102400 bytes allows roughly 75 KB of plaintext.
MAX_NOTE_BYTES=102400

# Rate limiting: max note creations per IP per window
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=3600000

# Path on the host where persistent data is stored.
# ONCE sets this to /storage automatically; for local dev use ./storage.
STORAGE_PATH=./storage
